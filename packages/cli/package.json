{
  "name": "api-scout",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "api-scout": "dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/tsup/dist/cli-default.js src/index.ts src/bin.ts --format esm --clean",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run --passWithNoTests",
    "dev": "npm run build && node dist/bin.js dev --project ../..",
    "scan": "npm run build && node dist/bin.js scan --project ../..",
    "doctor": "npm run build && node dist/bin.js doctor --project ../.."
  },
  "dependencies": {
    "@api-scout/core": "0.1.0",
    "@api-scout/dashboard-server": "0.1.0",
    "@api-scout/scanner": "0.1.0",
    "commander": "^14.0.1"
  }
}
