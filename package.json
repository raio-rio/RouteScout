{
  "name": "api-scout-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "AST-powered API test dashboard for Express and NestJS",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run typecheck && npm run --workspaces --if-present build",
    "typecheck": "tsc -b --force",
    "test": "npm run --workspaces --if-present test",
    "dev": "npm --workspace @api-scout/cli run dev",
    "scan": "npm --workspace @api-scout/cli run scan",
    "doctor": "npm --workspace @api-scout/cli run doctor"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
