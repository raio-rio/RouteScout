{
  "name": "api-scout-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "AST-powered backend endpoint scanner and dashboard for Express and NestJS",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run typecheck && npm run --workspaces --if-present build",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b --force",
    "test": "npm run --workspaces --if-present test",
    "dev": "npm --workspace api-scout run dev",
    "scan": "npm --workspace api-scout run scan",
    "doctor": "npm --workspace api-scout run doctor",
    "demo:start": "npm --prefix demo-backend run start",
    "demo:dashboard": "node packages/cli/dist/bin.js dev --project ./demo-backend --base-url http://localhost:3001 --no-open"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
